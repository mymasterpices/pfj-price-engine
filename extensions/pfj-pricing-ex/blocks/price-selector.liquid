{% comment %}
  ============================================================================
  PFJ Price Selector — Theme App Extension Block
  extensions/pfj-theme-ext/blocks/price-selector.liquid

  FIXES IN THIS VERSION:
  1. _surcharge only set when user has made a selection (not on base-only load)
  2. Intercepts theme's ATC button click → ensures _surcharge is current
  3. Also intercepts Ajax fetch('/cart/add.js') if theme uses drawer cart
  4. _surcharge = surcharge ONLY in cents (not total) — cart_transform adds it
     to the variant's own price server-side
  ============================================================================
{% endcomment %}

{% comment %} ── Rates from Shop Metafields → cents ── {% endcomment %}
{% assign mf    = shop.metafields.pfj_pricing %}
{% assign r_18k = mf.gold_18k.value | default: 0 | times: 100 | round %}
{% assign r_14k = mf.gold_14k.value | default: 0 | times: 100 | round %}
{% assign r_9k  = mf.gold_9k.value  | default: 0 | times: 100 | round %}
{% assign r_nat = mf.dia_nat.value  | default: 0 | times: 100 | round %}
{% assign r_lab = mf.dia_lab.value  | default: 0 | times: 100 | round %}

{% assign shop_currency     = shop.currency %}
{% assign shop_money_format = shop.money_format %}
{% assign uid               = block.id | remove: '-' | slice: 0, 10 %}

<div
  id="pfj-{{ uid }}"
  class="pfj-selector"
  data-uid="{{ uid }}"
  data-base-price="{{ product.selected_or_first_available_variant.price }}"
  data-currency="{{ shop_currency }}"
  data-money-format="{{ shop_money_format | escape }}"
  {{ block.shopify_attributes }}
>

  {% if block.settings.show_metal %}
  <div class="pfj-field">
    <label class="pfj-label" for="pfj-metal-{{ uid }}">
      {{- block.settings.metal_label | default: 'Metal' -}}
    </label>
    <div class="pfj-select-wrap">
      <select id="pfj-metal-{{ uid }}" class="pfj-select" data-pfj="metal">
        <option value="0" data-label="Standard">Standard</option>
        <option value="{{ r_18k }}" data-label="18K Gold">
          18K Gold{% if r_18k > 0 %} (+{{ r_18k | money }}){% endif %}
        </option>
        <option value="{{ r_14k }}" data-label="14K Gold">
          14K Gold{% if r_14k > 0 %} (+{{ r_14k | money }}){% endif %}
        </option>
        <option value="{{ r_9k }}" data-label="9K Gold">
          9K Gold{% if r_9k > 0 %} (+{{ r_9k | money }}){% endif %}
        </option>
      </select>
    </div>
  </div>
  {% endif %}

  {% if block.settings.show_diamond %}
  <div class="pfj-field">
    <label class="pfj-label" for="pfj-diamond-{{ uid }}">
      {{- block.settings.diamond_label | default: 'Diamond' -}}
    </label>
    <div class="pfj-select-wrap">
      <select id="pfj-diamond-{{ uid }}" class="pfj-select" data-pfj="diamond">
        <option value="0" data-label="No Diamond">No Diamond</option>
        <option value="{{ r_nat }}" data-label="Natural Diamond">
          Natural Diamond{% if r_nat > 0 %} (+{{ r_nat | money }}){% endif %}
        </option>
        <option value="{{ r_lab }}" data-label="Lab Grown Diamond">
          Lab Grown Diamond{% if r_lab > 0 %} (+{{ r_lab | money }}){% endif %}
        </option>
      </select>
    </div>
  </div>
  {% endif %}

  <div class="pfj-price-row">
    <span class="pfj-price-label">
      {{ block.settings.price_label | default: 'Total price' }}
    </span>
    <span class="pfj-price-value" id="pfj-price-{{ uid }}">
      {{ product.selected_or_first_available_variant.price | money }}
    </span>
  </div>

  <div class="pfj-breakdown" id="pfj-breakdown-{{ uid }}" hidden>
    <span>Base: <strong id="pfj-base-{{ uid }}"></strong></span>
    <span>+ surcharge: <strong id="pfj-sur-{{ uid }}"></strong></span>
  </div>

</div>

<style>
.pfj-selector { margin: 12px 0; }
.pfj-field    { margin-bottom: 14px; }

.pfj-label {
  display: block;
  font-size: .875rem;
  font-weight: 600;
  margin-bottom: 6px;
  color: rgb(var(--color-foreground, 18 18 18));
  letter-spacing: .04em;
}

.pfj-select-wrap { position: relative; }
.pfj-select-wrap::after {
  content: '';
  position: absolute;
  right: 12px;
  top: 50%;
  width: 8px;
  height: 8px;
  border-right: 1.5px solid currentColor;
  border-bottom: 1.5px solid currentColor;
  transform: translateY(-70%) rotate(45deg);
  pointer-events: none;
  opacity: .6;
}

.pfj-select {
  width: 100%;
  padding: .75rem 2.5rem .75rem 1rem;
  border: .1rem solid rgba(var(--color-foreground, 18 18 18), .45);
  border-radius: var(--inputs-radius, .4rem);
  background: rgb(var(--color-background, 255 255 255));
  color: rgb(var(--color-foreground, 18 18 18));
  font-size: 1rem;
  font-family: inherit;
  appearance: none;
  cursor: pointer;
  transition: border-color .15s;
  line-height: 1.5;
}
.pfj-select:focus {
  outline: .2rem solid rgba(var(--color-foreground, 18 18 18), .45);
  outline-offset: .3rem;
  border-color: rgba(var(--color-foreground, 18 18 18), .9);
}

.pfj-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 12px 0;
  border-top: .1rem solid rgba(var(--color-foreground, 18 18 18), .08);
  margin-top: 4px;
}
.pfj-price-label {
  font-size: .875rem;
  color: rgba(var(--color-foreground, 18 18 18), .7);
}
.pfj-price-value {
  font-size: 1.3rem;
  font-weight: 700;
  color: rgb(var(--color-foreground, 18 18 18));
  transition: color .15s;
}
.pfj-breakdown {
  display: flex;
  gap: 1.2rem;
  font-size: .75rem;
  color: rgba(var(--color-foreground, 18 18 18), .55);
  padding-bottom: 8px;
}
.pfj-breakdown[hidden] { display: none; }
</style>

<script>
(function () {
  'use strict';

  var UID        = {{ uid | json }};
  var blockEl    = document.getElementById('pfj-' + UID);
  if (!blockEl) return;

  var metalSel   = blockEl.querySelector('[data-pfj="metal"]');
  var diaSel     = blockEl.querySelector('[data-pfj="diamond"]');
  var priceEl    = document.getElementById('pfj-price-'     + UID);
  var brkEl      = document.getElementById('pfj-breakdown-' + UID);
  var baseEl     = document.getElementById('pfj-base-'      + UID);
  var surEl      = document.getElementById('pfj-sur-'       + UID);

  var basePrice  = parseInt(blockEl.dataset.basePrice, 10) || 0;
  var currency   = blockEl.dataset.currency   || 'INR';
  var moneyFmt   = blockEl.dataset.moneyFormat || '&#x20B9;{{amount}}';

  // ── Formatter ─────────────────────────────────────────────────────────────
  function money(cents) {
    if (window.Shopify && window.Shopify.formatMoney) {
      return window.Shopify.formatMoney(cents, moneyFmt);
    }
    var amt = (cents / 100).toFixed(2);
    return moneyFmt
      .replace('{{amount}}', amt)
      .replace('{{amount_no_decimals}}', Math.round(cents / 100))
      .replace('{{amount_with_comma_separator}}', amt);
  }

  // ── Current surcharge in cents ─────────────────────────────────────────────
  // KEY FIX: _surcharge = SURCHARGE ONLY (not total)
  // cart_transform reads the variant's own price + adds this surcharge
  function getSurchargeCents() {
    var m = parseInt(metalSel ? metalSel.value : 0, 10) || 0;
    var d = parseInt(diaSel   ? diaSel.value   : 0, 10) || 0;
    return m + d;
  }

  // ── Find product form ──────────────────────────────────────────────────────
  function getForm() {
    var el = blockEl.parentElement;
    while (el && el !== document.body) {
      var f = el.querySelector('form[action*="/cart/add"]');
      if (f) return f;
      el = el.parentElement;
    }
    return document.querySelector('form[action*="/cart/add"]');
  }

  // ── Ensure hidden input ────────────────────────────────────────────────────
  function setHidden(form, name, value) {
    var inp = form.querySelector('input[name="' + name + '"]');
    if (!inp) {
      inp      = document.createElement('input');
      inp.type = 'hidden';
      inp.name = name;
      form.appendChild(inp);
    }
    inp.value = value;
    return inp;
  }

  // ── Sync hidden inputs ─────────────────────────────────────────────────────
  function syncForm() {
    var form = getForm();
    if (!form) return;

    var sur    = getSurchargeCents();
    var mLabel = metalSel ? metalSel.options[metalSel.selectedIndex].dataset.label : 'Standard';
    var dLabel = diaSel   ? diaSel.options[diaSel.selectedIndex].dataset.label     : 'No Diamond';

    setHidden(form, 'properties[Metal]',          mLabel);
    setHidden(form, 'properties[Diamond]',         dLabel);

    // ── KEY: _surcharge = SURCHARGE CENTS ONLY ────────────────────────────
    // cart_transform_run.js reads variant cost from Shopify + adds this
    // DO NOT send total — that would double-count the base price
    setHidden(form, 'properties[_surcharge]',      sur);
    setHidden(form, 'properties[_currency]',       currency);
  }

  // ── Update price display ───────────────────────────────────────────────────
  function updateDisplay() {
    var sur   = getSurchargeCents();
    var total = basePrice + sur;

    if (priceEl) priceEl.textContent = money(total);

    if (brkEl) {
      if (sur > 0) {
        brkEl.removeAttribute('hidden');
        if (baseEl) baseEl.textContent = money(basePrice);
        if (surEl)  surEl.textContent  = money(sur);
      } else {
        brkEl.setAttribute('hidden', '');
      }
    }
  }

  // ── Full update ────────────────────────────────────────────────────────────
  function update() {
    updateDisplay();
    syncForm();
  }

  // ── Intercept ATC button to guarantee fresh sync before submit ────────────
  // Handles both native form submit and Ajax drawer cart themes (Dawn etc.)
  function interceptATC() {
    var form = getForm();
    if (!form) return;

    // Intercept native form submit
    form.addEventListener('submit', function () {
      syncForm(); // ensure latest values right before submit
    }, true);    // capture phase — runs before theme JS

    // Intercept Ajax fetch (Dawn drawer cart calls fetch('/cart/add.js'))
    // We patch fetch to inject properties into JSON body if it's a cart/add call
    var _fetch = window.fetch;
    window.fetch = function (url, opts) {
      if (typeof url === 'string' && url.includes('/cart/add')) {
        try {
          var body = JSON.parse(opts && opts.body ? opts.body : '{}');
          var sur  = getSurchargeCents();

          if (!body.properties) body.properties = {};

          var mLabel = metalSel ? metalSel.options[metalSel.selectedIndex].dataset.label : 'Standard';
          var dLabel = diaSel   ? diaSel.options[diaSel.selectedIndex].dataset.label     : 'No Diamond';

          body.properties['Metal']       = mLabel;
          body.properties['Diamond']     = dLabel;
          body.properties['_surcharge']  = sur;
          body.properties['_currency']   = currency;

          opts = Object.assign({}, opts, { body: JSON.stringify(body) });
        } catch (e) {
          // If body isn't JSON (e.g. FormData), fall through untouched
        }
      }
      return _fetch.apply(window, arguments);
    };
  }

  // ── Variant change — Pattern 1: custom event ──────────────────────────────
  document.addEventListener('variant:change', function (e) {
    if (e.detail && e.detail.variant && e.detail.variant.price !== undefined) {
      basePrice = e.detail.variant.price;
      blockEl.dataset.basePrice = basePrice;
      update();
    }
  });

  // ── Variant change — Pattern 2: Dawn MutationObserver ─────────────────────
  var form = getForm();
  if (form) {
    var varInput = form.querySelector('input[name="id"]');
    if (varInput) {
      new MutationObserver(function () {
        var priceItem = document.querySelector('[data-price-type="regular"]');
        if (priceItem && priceItem.dataset.price) {
          basePrice = parseInt(priceItem.dataset.price, 10);
          blockEl.dataset.basePrice = basePrice;
          update();
        }
      }).observe(varInput, { attributes: true, attributeFilter: ['value'] });
    }
  }

  if (metalSel) metalSel.addEventListener('change', update);
  if (diaSel)   diaSel.addEventListener('change',   update);

  document.addEventListener('shopify:section:load', function () {
    setTimeout(update, 100);
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  interceptATC();
  update();

}());
</script>

{% schema %}
{
  "name": "PFJ Price Selector",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_metal",
      "label": "Show metal selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_diamond",
      "label": "Show diamond selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "metal_label",
      "label": "Metal selector label",
      "default": "Metal"
    },
    {
      "type": "text",
      "id": "diamond_label",
      "label": "Diamond selector label",
      "default": "Diamond"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Total price label",
      "default": "Total price"
    }
  ]
}
{% endschema %}
